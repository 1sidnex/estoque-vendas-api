# Porta em que o servidor vai rodar
PORT=3000

# String de conexão do MongoDB (Atlas ou local)
MONGO_URI=mongodb+srv://usuario:senha@cluster.mongodb.net/estoque-vendas

# Segredo usado para assinar os tokens JWT (use uma string longa e aleatória)
JWT_SECRET=coloque_aqui_um_segredo_bem_grande_e_aleatorio

# Tempo de expiração do token
JWT_EXPIRES_IN=1d
